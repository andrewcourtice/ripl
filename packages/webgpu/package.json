{
    "name": "@ripl/webgpu",
    "version": "1.0.0-beta.1",
    "description": "WebGPU 3D rendering context for Ripl",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "repository": "https://github.com/andrewcourtice/ripl",
    "author": "Andrew Courtice <andrewcourtice@users.noreply.github.com>",
    "homepage": "https://www.ripl.rocks",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup"
    },
    "dependencies": {
        "@ripl/3d": "^1.0.0-beta.1",
        "@ripl/canvas": "^1.0.0-beta.1",
        "@ripl/core": "^1.0.0-beta.1",
        "@ripl/utilities": "^1.0.0-beta.1"
    }
}
