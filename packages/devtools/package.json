{
    "name": "@ripl/devtools",
    "version": "1.0.0-beta.3",
    "description": "Runtime bridge connecting Ripl contexts, scenes, and renderers to the Ripl devtools browser extension",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "repository": "https://github.com/andrewcourtice/ripl",
    "author": "Andrew Courtice <andrewcourtice@users.noreply.github.com>",
    "homepage": "https://www.ripl.run",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup && tsc -p tsconfig.build.json"
    },
    "dependencies": {
        "@ripl/core": "workspace:^",
        "@ripl/utilities": "workspace:^"
    }
}
