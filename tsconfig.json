{
    "compilerOptions": {
        "strict": true,
        "target": "ES2023",
        "module": "ESNext",
        "jsx": "preserve",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "isolatedModules": true,
        "removeComments": false,
        "skipLibCheck": true,
        "declaration": true,
        "stripInternal": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "lib": [
            "ESNext",
            "DOM",
        ],
        "types": [
            "vitest/importMeta",
            "@webgpu/types"
        ],
        "baseUrl": ".",
        "paths": {
            "@ripl/utilities": ["packages/utilities/src/index.ts"],
            "@ripl/vdom": ["packages/vdom/src/index.ts"],
            "@ripl/core": ["packages/core/src/index.ts"],
            "@ripl/svg": ["packages/svg/src/index.ts"],
            "@ripl/charts": ["packages/charts/src/index.ts"],
            "@ripl/3d": ["packages/3d/src/index.ts"],
            "@ripl/webgpu": ["packages/webgpu/src/index.ts"],
            "@ripl/test-utils": ["packages/test-utils/src/index.ts"],
        }
    },
    "files": [
        "global.d.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
